{
  "name": "production-master",
  "version": "0.1.0",
  "private": true,
  "description": "IDE thin client for the Production Master hosted incident-investigation service.",
  "license": "MIT",
  "author": "Tamir Cohen <tamircohen2468@gmail.com>",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "bash scripts/run-workspaces.sh build",
    "lint": "bash scripts/run-workspaces.sh lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:workspaces": "bash scripts/run-workspaces.sh test",
    "clean": "rm -rf coverage dist"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.7",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
